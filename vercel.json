{
  "version": 2,
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/pashudoc run build",
  "outputDirectory": "artifacts/pashudoc/dist/public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 512,
      "includeFiles": "artifacts/api-server/uploads/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
