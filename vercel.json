{
  "version": 2,
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/api-server exec node build-vercel.mjs && pnpm --filter @workspace/pashudoc run build",
  "outputDirectory": "artifacts/pashudoc/dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 512,
      "includeFiles": "api/_bundle.cjs"
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
