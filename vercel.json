{
  "version": 2,
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/pashudoc run build",
  "outputDirectory": "artifacts/pashudoc/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "VITE_API_URL/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
